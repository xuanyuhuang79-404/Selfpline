# Selfpline Environment Variables
# Copy this file to .env and fill in your values

# MySQL Configuration
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=selfpline
MYSQL_USER=selfpline
MYSQL_PASSWORD=change-me

# Redis Configuration
REDIS_PASSWORD=change-me-redis

# DeepSeek API Configuration
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# JWT Secret (MUST be at least 32 characters/256 bits for HS256)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Feature Toggles
REDIS_SESSION_ENABLED=true
